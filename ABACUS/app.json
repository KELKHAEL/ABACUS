{
  "expo": {
    "name": "ABACUS",
    "slug": "abacusimulation",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/abacus_logo.png",
    "scheme": "abacus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/abacus_logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mikhaelgarcia.ABACUS"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/abacus_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/abacus_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "023c2ca0-7c69-49d4-9fc9-b48505d2cdf6"
      }
    }
  }
}
